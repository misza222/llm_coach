OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://llm-api.example.com
MODEL_NAME=gpt-4o-mini-2024-07-18
DEBUG=true

# Persistence — omit for in-memory (no persistence between restarts)
# DATABASE_URL=sqlite:///sessions.db
# MAX_PAST_SESSIONS=3
# DATABASE_URL=postgresql://user:pass@localhost:5432/life_coach  # pragma: allowlist secret

# --- Authentication ---
# JWT_SECRET=your-secret-key-change-me
# JWT_ALGORITHM=HS256
# JWT_EXPIRY_MINUTES=10080

# Anonymous message limit before login required
# MAX_ANONYMOUS_MESSAGES=5

# OAuth — Google (https://console.cloud.google.com/apis/credentials)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# OAuth — Twitter/X (https://developer.twitter.com/en/portal/projects)
# TWITTER_CLIENT_ID=
# TWITTER_CLIENT_SECRET=

# OAuth — Facebook (https://developers.facebook.com/apps/)
# FACEBOOK_CLIENT_ID=
# FACEBOOK_CLIENT_SECRET=

# Base URL for OAuth callback redirects
# OAUTH_REDIRECT_BASE_URL=http://localhost:8000
